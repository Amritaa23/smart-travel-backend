# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=10

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — good for development)
DATABASE_URL=sqlite:///./travel.db
# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_travel

# ── Email / OTP ───────────────────────────────────────────────────────────────
# Leave blank to print OTPs to the console (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@smarttravel.com
